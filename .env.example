REDIS_URL=redis://localhost:6379/0
WEBAPP_URL=http://localhost:5173
ADMIN_IDS=123456789
BOT_USERNAME=luma_bot
OPENAI_API_KEY=
SENTRY_DSN=
RULES_LINK_1=https://example.com/rules
RULES_LINK_2=https://example.com/privacy
